# =============================================================================
# Root compose env — overrides for service-level docker-compose substitutions.
# Copy to .env. Per-app secrets live in apps/backend/.env and services/*/.env.
# =============================================================================

# Set NODE_ENV=development to relax fail-closed guards in dispatcher/mail/socket
# during local dev (so they boot without secrets configured). For prod-like
# behaviour locally, set =production and supply all *_TOKEN/*_SECRET values.
NODE_ENV=development

# ─── Shared secrets (only needed when NODE_ENV=production) ────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
DISPATCHER_SECRET=
MAIL_INTERNAL_TOKEN=

# Socket service
SECRET_KEY=
API_SECRET=
CORS_ORIGIN=http://localhost:3000

# ─── Mail provider (defaults to console driver) ──────────────────────────────
MAIL_DRIVER=console
MAIL_FROM=noreply@agentforge.com
MAIL_FROM_NAME=AgentForge
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
