# Server
PORT=3010
NODE_ENV=development

# Auth — shared secret. Unset in local dev means guard is disabled.
# Set in production; callers must send `x-dispatcher-token: <secret>` header.
DISPATCHER_SECRET=

# RabbitMQ
RABBITMQ_URL=amqp://agentforge:agentforge@localhost:5672

# Default retry config (overridable per message)
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000
RETRY_BACKOFF_MULTIPLIER=2

# HTTP client
HTTP_TIMEOUT=30000

# Target service URLs — override routes.json (format: {SERVICE_NAME}_URL, hyphens → underscores)
# BACKEND_URL=http://backend:8000
# MAIL_URL=http://mail:3011
# SOCKET_URL=http://socket:4000
# CODE_SANDBOX_URL=http://code-sandbox:8000
