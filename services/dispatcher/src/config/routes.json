{
  "services": {
    "backend": {
      "url": "http://backend:8000",
      "description": "AgentForge FastAPI backend (auth, agents, conversations, workflows)"
    },
    "mail": {
      "url": "http://mail:3011",
      "description": "Mail service (SendGrid / SMTP / Console)"
    },
    "socket": {
      "url": "http://socket:4000",
      "description": "WebSocket service (real-time chat, notifications)",
      "header": {
        "x-api-secret": "${SOCKET_API_SECRET}"
      }
    },
    "code-sandbox": {
      "url": "http://code-sandbox:8000",
      "description": "Code execution sandbox service"
    }
  }
}
