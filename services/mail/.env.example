# SendGrid (when MAIL_DRIVER=sendgrid)
SENDGRID_API_KEY=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

# SMTP (when MAIL_DRIVER=smtp) — works with Gmail, Zoho, Mailhog, SES SMTP, any SMTP server
