PORT=4000

# Public URL returned from POST /session — frontend uses this to open the
# WebSocket. Set per-env: localhost:4000 in dev, wss://socket.example.com in prod.
PUBLIC_URL=http://localhost:4000

# JWT secret used to sign + verify socket handshake tokens.
# Backend's `SECRET_KEY` must match (backend mints tokens today; socket verifies).
SECRET_KEY=change-me-shared-with-backend
JWT_ALGORITHM=HS256

# HTTP guard — dispatcher forwards `x-api-secret: <API_SECRET>` on /emit + /session.
# Must match backend's SOCKET_API_SECRET.
API_SECRET=change-me-socket-api-secret

CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379/0
