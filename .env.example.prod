# Production environment — copy to .env.prod and fill in real values.
# NEVER commit .env.prod to git.
#
# Generate fresh secrets:
#   SECRET_KEY:      openssl rand -hex 32
#   ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   POSTGRES_PASSWORD: openssl rand -base64 32 | tr -d '=+/'

# ─── App secrets ────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_Fernet_generate_key
DEBUG=false
LOG_FORMAT=json

# ─── Database / cache / queue ───────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/lc_agent
DATABASE_URL_SYNC=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/lc_agent
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ─── Public hostnames (browser-facing) ──────────────────────────────
# All three MUST be the real https URL the user types in the browser.
# Cookie scope, OAuth callback signing, and SSRF self-trust depend on
# these matching.
BASE_URL=https://app.example.com
FRONTEND_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com
PUBLIC_API_URL=https://app.example.com/api
PUBLIC_WS_URL=wss://app.example.com/api

# ─── Email (transactional) ──────────────────────────────────────────
# SMTP via the mail service, or set SENDGRID_API_KEY to use SendGrid.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SENDGRID_API_KEY=

# ─── Stripe (subscriptions + marketplace) ───────────────────────────
STRIPE_API_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_STARTER=price_CHANGE_ME
STRIPE_PRICE_STARTER_METERED=price_CHANGE_ME
STRIPE_PRICE_PRO=price_CHANGE_ME
STRIPE_PRICE_PRO_METERED=price_CHANGE_ME
STRIPE_SUCCESS_URL=https://app.example.com/hub/purchase-complete?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://app.example.com/hub
STRIPE_CONNECT_RETURN_URL=https://app.example.com/settings/payouts?ok=1
STRIPE_CONNECT_REFRESH_URL=https://app.example.com/settings/payouts?refresh=1
STRIPE_PLATFORM_FEE_BPS=1500

# ─── MoMo Business (VND payments) ───────────────────────────────────
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://payment.momo.vn

# ─── Observability ──────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── Tuning ─────────────────────────────────────────────────────────
WEB_CONCURRENCY=2
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_EXPIRE_DAYS=30
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_TTL_SECONDS=900
EXTERNAL_RATE_LIMIT_PER_MIN=60
SHARE_RATE_LIMIT_PER_MIN=30
AUDIT_LOG_RETENTION_DAYS=90
