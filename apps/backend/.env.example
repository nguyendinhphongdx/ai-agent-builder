# =============================================================================
# AgentForge Backend — Environment Variables
#
# Copy to .env and fill in values. All vars have sensible dev defaults in
# config.py — uncomment + override only what you need.
# =============================================================================


# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="AI Agent Builder"
DEBUG=true
API_PREFIX=/api

# Public base URL of this backend (used to build file URLs, callbacks)
BASE_URL=http://localhost:8001
# ─── Socket — frontend WebSocket URL ─────────────────────────────────────────
SOCKET_PUBLIC_URL=http://localhost:4000
# Frontend origin — used inside outgoing emails + OAuth redirects
FRONTEND_URL=http://localhost:3000
# CORS allow-list for browser requests. Must be valid JSON array.
CORS_ORIGINS=["http://localhost:3000"]

# ─── Database (PostgreSQL + pgvector) ────────────────────────────────────────
# Async driver for FastAPI request handlers
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lc_agent
# Sync driver for Alembic migrations + one-off scripts
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/lc_agent


# ─── Auth — JWT ──────────────────────────────────────────────────────────────
# REQUIRED in production. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_EXPIRE_DAYS=30

# Email verification code TTL (6-digit, brute-forceable → short)
EMAIL_VERIFICATION_TTL_MINUTES=15
# Password-reset magic link TTL (crypto-strong token → longer is OK)
PASSWORD_RESET_TTL_MINUTES=30

# ─── OAuth providers (leave empty to disable that provider) ──────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── Encryption for ai_credentials table ─────────────────────────────────────
# REQUIRED to store user-provided API keys. Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# ─── Dispatcher — internal API gateway ───────────────────────────────────────
# All service-to-service calls (mail, socket, code-sandbox) go through this.
# Docker: http://dispatcher:3010 | local: http://localhost:3010
DISPATCHER_URL=http://localhost:3010
# Shared secret. Empty → dispatcher guard disabled (dev only).
# Must match DISPATCHER_SECRET in services/dispatcher/.env
DISPATCHER_SECRET=


# ─── File storage ────────────────────────────────────────────────────────────
# Backend "local" | "s3" | "gcs" | "minio"
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# S3 / MinIO (when STORAGE_TYPE=s3 or minio)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# For MinIO: http://localhost:9000
S3_ENDPOINT_URL=

# GCS (when STORAGE_TYPE=gcs)
GCS_BUCKET=
# Service account credential — chọn 1 trong 3 cách:
#  1) Inline JSON (env-only deploy như Fly/Railway):
#       GCS_SA_JSON='{"type":"service_account","project_id":"...","private_key":"..."}'
#  2) Path tới file JSON đã mount:
#       GCS_SA_FILE=/app/secrets/gcp-sa.json
#  3) Chạy trên GCE/Cloud Run/GKE với SA gắn instance → không cần set gì.
GCS_SA_JSON=
GCS_SA_FILE=


# ─── Knowledge Base embeddings (platform-owned) ──────────────────────────────
# Provider + model + dimensions are snapshotted into each KB at create time,
# so changing these only affects *new* KBs. Existing KBs keep their snapshot.
EMBEDDING_PROVIDER=ollama              # ollama | openai
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Provider credentials — only the active provider's vars need to be set
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_EMBEDDING_API_KEY=
