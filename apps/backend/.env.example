# =============================================================================
# AgentForge Backend — Environment Variables
#
# Copy to .env and fill in. Every setting has a sensible dev default in
# ``app/platform/config.py``; this file only surfaces the ones a real
# deployment is likely to override. Run with no .env at all to get the
# in-memory dev profile.
# =============================================================================


# ─── Public URLs ─────────────────────────────────────────────────────────────
# Where this backend is reachable from (file URLs, OAuth callbacks).
BASE_URL=http://localhost:8001
# Browser-side origin — used inside outgoing emails + OAuth redirects.
FRONTEND_URL=http://localhost:3000
# CORS allow-list. Must be valid JSON array.
CORS_ORIGINS=["http://localhost:3000"]


# ─── Database (PostgreSQL + pgvector) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lc_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/lc_agent


# ─── Secrets — REQUIRED ──────────────────────────────────────────────────────
# JWT signing key. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-key-change-in-production
# Fernet key for the credentials table. Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# ─── Service-to-service ──────────────────────────────────────────────────────
# Dispatcher — internal API gateway (mail/socket/sandbox routing).
DISPATCHER_URL=http://localhost:3010
DISPATCHER_SECRET=
# Socket service — frontend WebSocket URL + HMAC for /emit calls.
SOCKET_PUBLIC_URL=http://localhost:4000
SOCKET_API_SECRET=dev-socket-api-secret
# Redis — rate limit on /api/external/* + /api/share/*. Empty disables.
REDIS_URL=redis://localhost:6379/0


# ─── OAuth for LOGIN (GitHub/Google identity) ────────────────────────────────
# Leave empty to disable that provider's login button.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── OAuth for EXTERNAL CONNECTIONS (Slack/Notion/Dropbox data sources) ──────
# Distinct from login OAuth. Powers "Connect <X>" in /settings/connections.
# Public URL the provider redirects back to (must register with each app):
OAUTH_REDIRECT_BASE_URL=http://localhost:8001
SLACK_CONNECTOR_CLIENT_ID=
SLACK_CONNECTOR_CLIENT_SECRET=
NOTION_CONNECTOR_CLIENT_ID=
NOTION_CONNECTOR_CLIENT_SECRET=
DROPBOX_CONNECTOR_CLIENT_ID=
DROPBOX_CONNECTOR_CLIENT_SECRET=


# ─── Slack inbound trigger ───────────────────────────────────────────────────
# Empty → /api/triggers/slack/events returns 503.
SLACK_SIGNING_SECRET=


# ─── File storage ────────────────────────────────────────────────────────────
# "local" (default) | "s3" | "gcs" | "minio"
STORAGE_TYPE=local

# Set when STORAGE_TYPE=s3 or minio
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=             # MinIO: http://localhost:9000

# Set when STORAGE_TYPE=gcs. Pick ONE auth path:
#   1) GCS_SA_JSON='{"type":"service_account",...}'   # inline JSON
#   2) GCS_SA_FILE=/app/secrets/gcp-sa.json           # mounted file
#   3) GCE / Cloud Run / GKE with instance SA         # no config needed
# GCS_BUCKET=
# GCS_SA_JSON=


# ─── Knowledge base embeddings ───────────────────────────────────────────────
# Provider + model + dims are snapshotted into each KB at create time, so
# changing these only affects *new* KBs.
EMBEDDING_PROVIDER=ollama              # ollama | openai
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_EMBEDDING_API_KEY=            # only when EMBEDDING_PROVIDER=openai

# Optional reranker (Cohere). Empty = retrieval falls back to score order.
# COHERE_API_KEY=


# ─── Sentry + Tracing (all optional) ─────────────────────────────────────────
# Empty SENTRY_DSN disables the SDK entirely.
SENTRY_DSN=
ENVIRONMENT=development                # development | staging | production
# OpenTelemetry collector endpoint. Empty disables tracing.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# Langfuse — LLM-call-level tracing (prompts + responses).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=


# ─── Stripe (Hub paid templates + platform subscriptions) ────────────────────
# Empty → paid checkout disabled (POST /purchase returns 503).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SUCCESS_URL=                   # incl. {CHECKOUT_SESSION_ID} token
# STRIPE_CANCEL_URL=
# Connect (author payouts):
# STRIPE_CONNECT_RETURN_URL=
# STRIPE_CONNECT_REFRESH_URL=
# Platform subscriptions:
# STRIPE_BILLING_SUCCESS_URL=
# STRIPE_BILLING_CANCEL_URL=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_STARTER_METERED=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_PRO_METERED=


# ─── MoMo (VND payments — Vietnam) ───────────────────────────────────────────
# Empty MOMO_PARTNER_CODE → VND checkout disabled.
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=
# MOMO_RETURN_URL=
# MOMO_NOTIFY_URL=
