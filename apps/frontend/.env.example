# =============================================================================
# AgentForge Frontend — Environment Variables
#
# Next.js convention: vars prefixed with NEXT_PUBLIC_ are exposed to the
# browser bundle. Anything else is build-time only (server components / API
# routes). Copy to .env.local and override what you need.
# =============================================================================

# Backend REST + WebSocket base URL. Used by the API client (lib/api/client.ts)
# and socket helper. Should match the backend's BASE_URL + API_PREFIX.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# CDN / origin for the embed widget loader. Defaults to ${API_URL}/static/embed.js
# so leaving this empty is fine in dev. Override in prod when you serve embed.js
# from a CDN (e.g. https://cdn.example.com/embed.js).
NEXT_PUBLIC_EMBED_URL=


# ─── Sentry — error tracking ─────────────────────────────────────────────────
# Browser SDK — exposed to the bundle. Empty disables the SDK entirely.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=
# 0..1 — perf trace sample rate. 0 = errors only.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Server SDK (Node + Edge runtimes). Set the same DSN as the backend if
# you want browser, Next server, and FastAPI errors in the same project.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Source map upload (CI/CD only — leave blank for local dev).
# Get a token at https://sentry.io/settings/account/api/auth-tokens/
# with the `project:releases` scope.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
